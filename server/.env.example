# Gmail IMAP credentials
# 1. Enable IMAP: Gmail Settings > See all settings > Forwarding and POP/IMAP > Enable IMAP
# 2. Create App Password: Google Account > Security > 2-Step Verification > App passwords
#    Generate one for "Mail" on "Windows Computer"
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# How often to check for new emails (seconds)
POLL_INTERVAL=60

# API server port
PORT=5555

# Database file path
DB_PATH=trades.db
